  "modint": {
    "prefix": "modint",
    "body": [
      "const int MOD = 1e9+7;",
      "long long modexp(long long a, long long b) {",
      "    long long res = 1;",
      "    while (b) {",
      "        if (b & 1) res = (res * a) % MOD;",
      "        a = (a * a) % MOD;",
      "        b >>= 1;",
      "    }",
      "    return res;",
      "}"
    ]
  },

  "sieve": {
    "prefix": "sieve",
    "body": [
      "const int N = 1e6+5;",
      "vector<bool> prime(N, true);",
      "",
      "void sieve() {",
      "    prime[0] = prime[1] = false;",
      "    for (int i = 2; i * i < N; i++) {",
      "        if (prime[i]) {",
      "            for (int j = i * i; j < N; j += i)",
      "                prime[j] = false;",
      "        }",
      "    }",
      "}"
    ]
  },

  "dsu": {
    "prefix": "dsu",
    "body": [
      "struct DSU {",
      "    vector<int> parent, size;",
      "",
      "    DSU(int n) {",
      "        parent.resize(n);",
      "        size.resize(n, 1);",
      "        iota(parent.begin(), parent.end(), 0);",
      "    }",
      "",
      "    int find(int x) {",
      "        if (x == parent[x]) return x;",
      "        return parent[x] = find(parent[x]);",
      "    }",
      "",
      "    void unite(int a, int b) {",
      "        a = find(a);",
      "        b = find(b);",
      "        if (a != b) {",
      "            if (size[a] < size[b]) swap(a, b);",
      "            parent[b] = a;",
      "            size[a] += size[b];",
      "        }",
      "    }",
      "};"
    ]
  },

