{
  "reset": {
    "prefix": "reset",
    "body": [
      "* {",
      "  margin: 0;",
      "  padding: 0;",
      "  box-sizing: border-box;",
      "}"
    ]
  },

  "body_base": {
    "prefix": "body",
    "body": [
      "body {",
      "  font-family: ${1:system-ui, sans-serif};",
      "  line-height: ${2:1.5};",
      "  background: ${3:#f9fafb};",
      "  color: ${4:#111};",
      "}"
    ]
  },

  "flex_center": {
    "prefix": "flexc",
    "body": [
      "display: flex;",
      "justify-content: ${1:center};",
      "align-items: ${2:center};"
    ]
  },

  "grid_center": {
    "prefix": "gridc",
    "body": ["display: grid;", "place-items: ${1:center};"]
  },

  "container": {
    "prefix": "container",
    "body": [
      "max-width: ${1:1200px};",
      "margin: ${2:0 auto};",
      "padding: ${3:0 16px};"
    ]
  },

  "button_base": {
    "prefix": "btn",
    "body": [
      "padding: ${1:10px} ${2:16px};",
      "border: ${3:none};",
      "border-radius: ${4:8px};",
      "cursor: pointer;",
      "transition: all ${5:0.2s} ease;",
      "font-weight: ${6:500};"
    ]
  },

  "button_primary": {
    "prefix": "btnp",
    "body": [
      "background: ${1:#3b82f6};",
      "color: ${2:white};",
      "",
      ":hover {",
      "  background: ${3:#2563eb};",
      "  transform: translateY(${4:-2px});",
      "}"
    ]
  },

  "button_outline": {
    "prefix": "btno",
    "body": [
      "background: transparent;",
      "border: ${1:2px solid #3b82f6};",
      "color: ${2:#3b82f6};",
      "",
      ":hover {",
      "  background: ${3:#3b82f6};",
      "  color: ${4:white};",
      "}"
    ]
  },

  "card": {
    "prefix": "card",
    "body": [
      "background: ${1:white};",
      "padding: ${2:16px};",
      "border-radius: ${3:12px};",
      "box-shadow: ${4:0 4px 10px rgba(0,0,0,0.08)};"
    ]
  },

  "card_hover": {
    "prefix": "cardh",
    "body": [
      "transition: ${1:0.2s} ease;",
      "",
      ":hover {",
      "  transform: translateY(${2:-4px});",
      "  box-shadow: ${3:0 10px 20px rgba(0,0,0,0.12)};",
      "}"
    ]
  },

  "input": {
    "prefix": "input",
    "body": [
      "padding: ${1:10px} ${2:12px};",
      "border: ${3:1px solid #ccc};",
      "border-radius: ${4:6px};",
      "outline: none;",
      "transition: ${5:0.2s};"
    ]
  },

  "input_focus": {
    "prefix": "focus",
    "body": [
      ":focus {",
      "  border-color: ${1:#3b82f6};",
      "  box-shadow: ${2:0 0 0 3px rgba(59,130,246,0.2)};",
      "}"
    ]
  },

  "navbar": {
    "prefix": "nav",
    "body": [
      ".navbar {",
      "  display: flex;",
      "  justify-content: space-between;",
      "  align-items: center;",
      "  padding: ${1:16px 24px};",
      "  background: ${2:#111};",
      "  color: ${3:white};",
      "}"
    ]
  },

  "navbar_links": {
    "prefix": "navlinks",
    "body": [
      ".navbar ul {",
      "  display: flex;",
      "  gap: ${1:16px};",
      "  list-style: none;",
      "}"
    ]
  },

  "grid_auto": {
    "prefix": "gridauto",
    "body": [
      "display: grid;",
      "grid-template-columns: repeat(auto-fit, minmax(${1:200px}, 1fr));",
      "gap: ${2:16px};"
    ]
  },

  "media_query": {
    "prefix": "media",
    "body": ["@media (max-width: ${1:768px}) {", "  $2", "}"]
  },

  "shadow_sm": {
    "prefix": "shadow",
    "body": ["box-shadow: ${1:0 2px 6px rgba(0,0,0,0.08)};"]
  },

  "shadow_lg": {
    "prefix": "shadowlg",
    "body": ["box-shadow: ${1:0 10px 25px rgba(0,0,0,0.15)};"]
  },

  "glass": {
    "prefix": "glass",
    "body": [
      "background: rgba(255,255,255,${1:0.1});",
      "backdrop-filter: blur(${2:10px});",
      "-webkit-backdrop-filter: blur(${3:10px});",
      "border: 1px solid rgba(255,255,255,${4:0.2});",
      "border-radius: ${5:12px};"
    ]
  },

  "fade_in": {
    "prefix": "fade",
    "body": [
      "@keyframes fadeIn {",
      "  from { opacity: 0; transform: translateY(${1:10px}); }",
      "  to { opacity: 1; transform: translateY(0); }",
      "}",
      "",
      "animation: fadeIn ${2:0.3s} ease forwards;"
    ]
  },

  "slide_in": {
    "prefix": "slide",
    "body": [
      "@keyframes slideIn {",
      "  from { transform: translateX(${1:-20px}); opacity: 0; }",
      "  to { transform: translateX(0); opacity: 1; }",
      "}",
      "",
      "animation: slideIn ${2:0.3s} ease forwards;"
    ]
  },

  "absolute_center": {
    "prefix": "abcenter",
    "body": [
      "position: absolute;",
      "top: ${1:50%};",
      "left: ${2:50%};",
      "transform: translate(-50%, -50%);"
    ]
  },

  "full_screen_center": {
    "prefix": "fullc",
    "body": [
      "display: flex;",
      "justify-content: center;",
      "align-items: center;",
      "height: ${1:100vh};",
      "width: ${2:100vw};"
    ]
  },

  "dashboard_layout": {
    "prefix": "dashboard",
    "body": [
      "display: grid;",
      "grid-template-columns: ${1:240px} 1fr;",
      "height: 100vh;",
      "",
      ".sidebar {",
      "  background: ${2:#111};",
      "  color: ${3:white};",
      "  padding: ${4:20px};",
      "}",
      "",
      ".main {",
      "  background: ${5:#f9fafb};",
      "  padding: ${6:20px};",
      "}"
    ]
  },

  "landing_layout": {
    "prefix": "landing",
    "body": [
      "display: flex;",
      "flex-direction: column;",
      "justify-content: center;",
      "align-items: center;",
      "height: 100vh;",
      "text-align: center;",
      "",
      "h1 { font-size: ${1:48px}; }",
      "p { color: ${2:#666}; }"
    ]
  }
}
